# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NewebPay (藍新金流)
# Get these from the NewebPay merchant dashboard
NEWEBPAY_MERCHANT_ID=your-merchant-id
NEWEBPAY_HASH_KEY=your-32-char-hash-key
NEWEBPAY_HASH_IV=your-16-char-hash-iv

# App URL (used for payment callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Sheets sync (optional)
# Deploy google-apps-script/OrdersSheet.gs as a Web App and paste the URL here
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Supabase webhook secret (any random string — must match what you set in Supabase webhook headers)
WEBHOOK_SECRET=your-random-secret-here

# Transactional email via Brevo (brevo.com — 300 free emails/day)
# Find API key under: Brevo dashboard → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx

# The "From" address — must be verified in Brevo → Senders & Domains → Domains
# Add mat-side.com as a domain and paste the DNS records into your Squarespace DNS settings
EMAIL_FROM=sales@mat-side.com
EMAIL_FROM_NAME=Matside

# Admin email — receives a copy of every order confirmation
ADMIN_EMAIL=catchjiujitsu@gmail.com
